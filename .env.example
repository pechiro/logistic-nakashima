# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Database (Supabase Postgres) -------------------------------------------
# Get these from your Supabase project: Connect -> ORMs -> Prisma.
# DATABASE_URL = transaction pooler (port 6543, pgbouncer). DIRECT_URL = session
# pooler (port 5432), used for migrations / db push.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# --- Session signing --------------------------------------------------------
# Any long random string. Makes session cookies non-forgeable.
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Supabase (product photos + optional Supabase Auth) ---------------------
# Get these from the Supabase dashboard: Project Settings -> API.
#   SUPABASE_URL              = Project URL, e.g. https://<project-ref>.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY = "service_role" secret — server-side only. Powers
#                               photo uploads to the public "product-images" bucket.
#   SUPABASE_ANON_KEY         = "anon" public key. When set, logins are verified
#                               against Supabase Auth first (so users created in
#                               the Supabase Dashboard can sign in), falling back
#                               to the local password otherwise. Leave blank to
#                               keep local-only auth.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_ANON_KEY=""

# --- Seed login password (used only by `db:seed`) ---------------------------
# The seed ensures ONLY the "cucho" login, non-destructively (upsert). It never
# recreates a predefined team list — other users are managed directly (e.g. in
# the Supabase Dashboard).
SEED_PW_CUCHO=""
