# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Database (Supabase Postgres) -------------------------------------------
# Get these from your Supabase project: Connect -> ORMs -> Prisma.
# DATABASE_URL = transaction pooler (port 6543, pgbouncer). DIRECT_URL = session
# pooler (port 5432), used for migrations / db push.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# --- Session signing --------------------------------------------------------
# Any long random string. Makes session cookies non-forgeable.
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Team login passwords (used only by `bun run db:seed`) ------------------
# One per authorized user in prisma/seed.ts. Choose strong values.
SEED_PW_RBOCANEGRA=""
SEED_PW_JTULLER=""
SEED_PW_GSALAZAR=""
SEED_PW_CHURTADO=""
SEED_PW_DIANAHOL=""
