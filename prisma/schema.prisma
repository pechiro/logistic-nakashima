// Stockroom — inventory data model
// Prisma 6 + Supabase Postgres (shared cloud DB). See src/lib/prisma.ts for the singleton.

generator client {
  provider = "prisma-client-js"
  // Generate into the project (not node_modules) so Turbopack resolves it
  // directly instead of treating @prisma/client as an unresolved external.
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Used for migrations / db push; when DATABASE_URL is a pooled (pgbouncer)
  // connection, this must be a direct connection. Here both are the same direct URL.
  directUrl = env("DIRECT_URL")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  sku          String   @unique
  category     String
  // Optional free-text notes / description. Nullable — blank means unset.
  description  String?
  // Units currently on hand.
  quantity     Int      @default(0)
  // Price per unit. Stored as a float for now; revisit as integer cents
  // once valuation/reporting lands.
  unitPrice    Float    @default(0)
  // Reorder threshold: quantity <= reorderLevel means "low stock".
  reorderLevel Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements    StockMovement[]
  projectItems ProjectItem[]

  @@index([category])
}

// The single demo user that gates the app. Minimal by design: no signup, no
// roles, no reset. `passwordHash` is a scrypt `salt:hash` string (see src/lib/auth.ts).
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// One row per stock change. `resultingQuantity` snapshots the product's quantity
// immediately after the movement so the log reads correctly even as stock keeps moving.
model StockMovement {
  id                String   @id @default(cuid())
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId         String
  // Project this movement relates to, when any: set for a dispatch to a project
  // ("OUT") and a return from a project ("RETURN"). Null for plain warehouse
  // Entrada/Salida. SetNull so deleting a project keeps the historical movement
  // (it just unlinks the project name).
  project           Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId         String?
  type              String // "IN" | "OUT" | "RETURN"
  amount            Int // positive magnitude of the change
  resultingQuantity Int // product quantity after this movement
  // Optional label for the reason of the movement, e.g. "DESPACHO A PROYECTO".
  note              String?
  createdAt         DateTime @default(now())

  @@index([productId])
  @@index([projectId])
  @@index([createdAt])
}

// A project that warehouse materials get dispatched to.
model Project {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  items     ProjectItem[]
  movements StockMovement[]

  @@index([createdAt])
}

// Materials assigned to a project. Each row records how much of a product was
// requested/dispatched to a given project. Creating one deducts warehouse stock
// (see src/app/proyectos/actions.ts assignMaterial).
model ProjectItem {
  id                String   @id @default(cuid())
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId         String
  quantityRequested Int
  createdAt         DateTime @default(now())

  @@index([projectId])
  @@index([productId])
}
